<div class="main-container">
    <div class="large-block">
        <h2>Realizar Pago</h2>
        <p>Transacciones seguras para tu servicio de diseño.</p>
        <form action="/payment/add" method="POST">
            <input type="email" name="email" placeholder="Correo Electrónico" required>
            <input type="text" name="cardName" placeholder="Nombre del Titular" required>
            <input type="text" name="cardNumber" placeholder="Número de Tarjeta" required>
            <input type="text" name="expiryMonth" placeholder="Mes Exp." required>
            <input type="text" name="expiryYear" placeholder="Año Exp." required>
            <input type="text" name="cvv" placeholder="CVV/CVC" required>
            <input type="number" name="amount" placeholder="Monto a Pagar" required>
            <input type="submit" value="Pagar">
        </form>
    </div>

    <div class="small-blocks">
        <div class="small-block">
            <h3>Seguridad Garantizada</h3>
            <p>Protegemos tu información financiera.</p>
        </div>
        <div class="small-block">
            <h3>Múltiples Métodos de Pago</h3>
            <p>Tarjetas de crédito, débito y transferencias.</p>
        </div>
        <div class="small-block">
            <h3>Soporte 24/7</h3>
            <p>Estamos aquí para resolver cualquier duda.</p>
        </div>
    </div>
</div>